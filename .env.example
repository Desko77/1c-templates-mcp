# ============================================================
# 1c-templates-mcp - configuration example
# ============================================================
# Copy this file to `.env` and adjust values for your setup.
# Lines starting with # are comments. Uncomment what you need.
# ============================================================


# ============================================================
# Quick launch commands (not env vars, just for reference)
# ============================================================
#
# CPU profile (universal, works everywhere):
#   docker compose --profile cpu up -d
#
# GPU profile (NVIDIA GPU + nvidia-container-toolkit required):
#   docker compose --profile gpu up -d
#
# Local run without Docker:
#   pip install -r requirements.txt
#   python -m app.main
#
# View logs:
#   docker compose logs -f template-search-mcp
#   docker compose logs -f template-search-mcp-gpu
#
# Stop:
#   docker compose --profile cpu down
#   docker compose --profile gpu down
#
# Rebuild after requirements.txt change:
#   docker compose --profile gpu build --no-cache
#
# ============================================================


# ============================================================
# Server
# ============================================================

# HTTP port for web UI and MCP endpoint.
HTTP_PORT=8004

# Transport: false = Streamable HTTP (default), true = SSE.
USESSE=false


# ============================================================
# Runtime flags
# ============================================================

# Rebuild ChromaDB vector index on startup. Set to true after template
# changes or embedding-model changes. Set to false for fast restarts
# when templates and embedding model haven't changed.
RESET_CHROMA=true

# Re-download embedding model files on startup (clears model_cache/).
# Usually false — models are cached in a Docker volume and reused.
RESET_CACHE=true


# ============================================================
# Embedding provider
# ============================================================

# Provider selector:
#   auto   - try OpenAI-compatible API first; on failure fall back to
#            local SentenceTransformer. Good default for mixed setups.
#   local  - local SentenceTransformer only. Self-contained, no external
#            API dependency. Recommended for stable deployments.
#   openai - OpenAI-compatible API only. Hard-fails if API unreachable
#            (no silent fallback). Use for production with guaranteed API.
EMBEDDING_PROVIDER=local


# ============================================================
# Local SentenceTransformer model
# Used when EMBEDDING_PROVIDER=local, or as fallback in 'auto'.
# Must be a valid HuggingFace model identifier.
# ============================================================

# --- Option A: Best Russian quality (recommended with GPU) ---
# ai-forever/ru-en-RoSBERTa: 404M params, 1024 dim, ~1.6 GB.
# Indexing 2262 templates: ~1 min on GPU, ~5-10 min on CPU.
# Best semantic quality for Russian BSL descriptions.
EMBEDDING_MODEL=ai-forever/ru-en-RoSBERTa

# --- Option B: Fast on CPU, smaller footprint ---
# intfloat/multilingual-e5-small: 118M params, 384 dim, ~450 MB.
# Good multilingual baseline, works fine on CPU.
# EMBEDDING_MODEL=intfloat/multilingual-e5-small

# --- Option C: Large multilingual, GPU recommended ---
# intfloat/multilingual-e5-large: 560M params, 1024 dim, ~2.2 GB.
# High general-purpose quality, slow on CPU.
# EMBEDDING_MODEL=intfloat/multilingual-e5-large


# ============================================================
# OpenAI-compatible API (LM Studio, Ollama, vLLM, OpenAI)
# Active when EMBEDDING_PROVIDER=openai or primary in 'auto'.
# ============================================================

# API base URL. On Windows/Mac host from Docker, use host.docker.internal.
# OPENAI_API_BASE=http://host.docker.internal:1234

# API key. For LM Studio/Ollama any string works. For OpenAI use sk-...
# OPENAI_API_KEY=lm-studio

# Model name on the API server. Different for each backend:
#   LM Studio: internal name of the loaded model (e.g. text-embedding-multilingual-e5-large-instruct)
#   OpenAI:    text-embedding-3-small, text-embedding-3-large, text-embedding-ada-002
#   Ollama:    nomic-embed-text, mxbai-embed-large, ...
# OPENAI_MODEL=text-embedding-multilingual-e5-large-instruct


# ============================================================
# Ready-to-use recipes (uncomment the block you want)
# ============================================================

# --- Recipe 1: Fully local, Russian-optimized (current default) ---
# EMBEDDING_PROVIDER=local
# EMBEDDING_MODEL=ai-forever/ru-en-RoSBERTa

# --- Recipe 2: Fully local, CPU-friendly (no GPU) ---
# EMBEDDING_PROVIDER=local
# EMBEDDING_MODEL=intfloat/multilingual-e5-small

# --- Recipe 3: LM Studio on host with fallback to local ---
# EMBEDDING_PROVIDER=auto
# OPENAI_API_BASE=http://host.docker.internal:1234
# OPENAI_API_KEY=lm-studio
# OPENAI_MODEL=text-embedding-multilingual-e5-large-instruct
# EMBEDDING_MODEL=intfloat/multilingual-e5-small

# --- Recipe 4: OpenAI API (production, no fallback) ---
# EMBEDDING_PROVIDER=openai
# OPENAI_API_BASE=https://api.openai.com
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=text-embedding-3-small
